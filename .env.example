# --- Health Records demo / Vercel deployment ---

# OpenRouter API key for the AI serverless functions (api/ai/*).
# Set this in the Vercel project's Environment Variables (NOT committed).
# If missing, the AI functions gracefully fall back to canned responses.
OPENROUTER_API_KEY=

# Local-Claude-CLI chat gateway for the records assistant (api/ai/chat.mjs).
# Set both in the Vercel project's Environment Variables (NOT committed).
# If either is missing, the chat function gracefully falls back to canned responses.
CHAT_GATEWAY_URL=
CHAT_GATEWAY_SECRET=

# Turns on browser-only demo mode: the prototype's /api/* calls resolve against
# an in-memory store instead of the local Node server. The Vercel build enables
# this automatically via `npm run build:demo` (vite --mode demo loads .env.demo).
# The plain `npm run build` used by the Electron desktop app stays demo-free.
VITE_DEMO=true
